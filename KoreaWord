local function isMyTurn()
    local gameGui = player.PlayerGui:FindFirstChild("GameGui")
    if not gameGui then return false end
    local lbl = gameGui:FindFirstChild("TimeLeftLabel")
    if not lbl then return false end
    local name = lbl.Text:match("^(.-)의 차례")
    if not name then return false end
    return name == player.Name or name == player.DisplayName
end

local function getRequiredChar()
    local gameGui = player.PlayerGui:FindFirstChild("GameGui")
    if not gameGui then return nil end
    local triesFrame = gameGui:FindFirstChild("TriesFrame")
    if not triesFrame then return nil end
    local tipLabel = triesFrame:FindFirstChild("SpectatorTipLabel")
    if not tipLabel then return nil end
    local raw = tipLabel.Text:match("'(.-)'")
    if not raw then return nil end
    raw = raw:gsub("^%s+", ""):gsub("%s+$", "")
    if raw == "" then return nil end
    return raw
end

local function isSpecialWord(w)
    for _, sw in ipairs(specialWords) do
        if string.sub(w, -#sw) == sw then
            return true
        end
    end
    return false
end

local I_CLASS_JUNG = {[2] = true, [6] = true, [7] = true, [12] = true, [17] = true, [20] = true}

local function getDueumVariant(reqChar)
    if not reqChar or reqChar == "" then return nil end

    local firstChar, restChars = nil, {}
    for _, cp in utf8.codes(reqChar) do
        if not firstChar then
            firstChar = utf8.char(cp)
        else
            table.insert(restChars, utf8.char(cp))
        end
    end

    if not firstChar then return nil end

    local code = utf8.codepoint(firstChar)
    if code < 0xAC00 or code > 0xD7A3 then
        return nil
    end

    local offset = code - 0xAC00
    local jong = offset % 28
    local jung = math.floor(offset / 28) % 21
    local cho = math.floor(offset / 28 / 21)

    local newCho = nil
    if cho == 5 then
        newCho = I_CLASS_JUNG[jung] and 11 or 2
    elseif cho == 2 and I_CLASS_JUNG[jung] then
        newCho = 11
    end

    if not newCho then
        return nil
    end

    local newFirstChar = utf8.char(0xAC00 + (newCho * 21 + jung) * 28 + jong)
    return newFirstChar .. table.concat(restChars)
end

local function pickAutoWord(char)
    local variant = getDueumVariant(char)
    local specialCandidates = {}

    for _, w in ipairs(words) do
        local matches = string.sub(w, 1, #char) == char
        if not matches and variant then
            matches = string.sub(w, 1, #variant) == variant
        end

        if matches and not autoUsedWords[w] and isSpecialWord(w) then
            table.insert(specialCandidates, w)
        end
    end

    if #specialCandidates > 0 then
        local chosen = specialCandidates[1]
        autoUsedWords[chosen] = true
        return chosen
    end

    return nil
end

