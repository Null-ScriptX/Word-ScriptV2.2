local function findDescendantTextBox(root, nameContains)
    for _, inst in ipairs(root:GetDescendants()) do
        if inst:IsA("TextBox") then
            if not nameContains or string.find(string.lower(inst.Name), nameContains) then
                return inst
            end
        end
    end
    return nil
end

local function resolveCustomPath()
    if not CUSTOM_CHAT_BOX_PATH then return nil end
    local current = player:WaitForChild("PlayerGui")
    for _, name in ipairs(CUSTOM_CHAT_BOX_PATH) do
        current = current:FindFirstChild(name)
        if not current then return nil end
    end
    if current and current:IsA("TextBox") then
        return current
    end
    return nil
end

local function findChatBox()
    local custom = resolveCustomPath()
    if custom then return custom end

    local playerGui = player:WaitForChild("PlayerGui")

    local typeFrame = playerGui:FindFirstChild("TypeFrame", true)
    if typeFrame then
        local tb = typeFrame:FindFirstChild("TextBox")
        if tb and tb:IsA("TextBox") then
            return tb
        end
        local tb2 = findDescendantTextBox(typeFrame)
        if tb2 then return tb2 end
    end

    local box1 = findDescendantTextBox(playerGui, "chatbar")
    if box1 then return box1 end

    local chatGui = playerGui:FindFirstChild("Chat")
    if chatGui then
        local box2 = findDescendantTextBox(chatGui)
        if box2 then return box2 end
    end

    local ok, box3 = pcall(function()
        local CoreGui = game:GetService("CoreGui")
        local b = findDescendantTextBox(CoreGui, "chatbar")
        if not b then
            local chatFolder = CoreGui:FindFirstChild("Chat", true)
            if chatFolder then
                b = findDescendantTextBox(chatFolder)
            end
        end
        return b
    end)
    if ok and box3 then return box3 end

    return nil
end

local function splitUtf8Chars(str)
    local chars = {}
    for _, codepoint in utf8.codes(str) do
        table.insert(chars, utf8.char(codepoint))
    end
    return chars
end

local activeTypingToken = nil 

local function typeTextIntoBox(chatBox, text, onDone)
    local myToken = {}
    activeTypingToken = myToken

    task.spawn(function()
        chatBox.Text = ""

        local chars = splitUtf8Chars(text)
        for _, ch in ipairs(chars) do
            if activeTypingToken ~= myToken then
                return
            end
            chatBox.Text = chatBox.Text .. ch
            task.wait(TYPE_DELAY)
        end

        if activeTypingToken == myToken and onDone then
            onDone()
        end
    end)
end

