local function update()
    local text = box.Text
    clear()
    
    if text == "" or currentCategory == "자동 입력" then return end

    local results = {}
    for _,word in ipairs(words) do
        if string.sub(word,1,#text) == text then
            table.insert(results, word)
        end
    end

    local specials, normals = {}, {}
    for _,w in ipairs(results) do
        local isSpecial = false
        for _,sw in ipairs(specialWords) do
            if string.sub(w, -string.len(sw)) == sw then
                isSpecial = true
                break
            end
        end

        if currentCategory == "단어" then
            if isSpecial then table.insert(specials, w) else table.insert(normals, w) end
            
        elseif currentCategory == "한 방" then
            if isSpecial then table.insert(specials, w) end
            
        elseif currentCategory == "긴거" then
            if not isSpecial then
                local wordLen = 0
                pcall(function() wordLen = utf8.len(w) end)
                if wordLen == 0 then wordLen = string.len(w)/3 end
                
                if wordLen >= 3 then
                    table.insert(normals, w)
                end
            end
        end
    end

    table.sort(normals, function(a,b) return #a > #b end)
    if currentCategory == "긴거" then
        table.sort(specials, function(a,b) return #a > #b end)
    end

    local orderIndex = 0

    for _,item in ipairs(specials) do
        orderIndex += 1
        createResult(item, true, orderIndex)
    end

    for _,item in ipairs(normals) do
        orderIndex += 1
        createResult(item, false, orderIndex)
    end

    task.defer(function()
        scrolling.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y + 10)
    end)
end

