local function switchTab(tabName)
    mainTab.BackgroundColor3 = (tabName == "Main") and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(32, 32, 32)
    mainTab.TextColor3 = (tabName == "Main") and Color3.fromRGB(15, 15, 15) or Color3.fromRGB(180, 180, 180)

    settingTab.BackgroundColor3 = (tabName == "Setting") and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(32, 32, 32)
    settingTab.TextColor3 = (tabName == "Setting") and Color3.fromRGB(15, 15, 15) or Color3.fromRGB(180, 180, 180)

    local isMain = (tabName == "Main")
    box.Visible = isMain
    searchButton.Visible = isMain
    categoryBar.Visible = isMain
    divider.Visible = isMain
    settingsFrame.Visible = not isMain
    
    if isMain then
        if currentCategory == "자동 입력" then
            scrolling.Visible = false
            botFrame.Visible = true
        else
            scrolling.Visible = true
            botFrame.Visible = false
        end
    else
        scrolling.Visible = false
        botFrame.Visible = false
    end
end

