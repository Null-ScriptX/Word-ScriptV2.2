    targetBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    
    local textWidth = targetBtn.TextBounds.X
    if textWidth == 0 then
        if categoryName == "단어" then textWidth = 40
        elseif categoryName == "한 방" then textWidth = 46
        elseif categoryName == "긴거" then textWidth = 40
        elseif categoryName == "자동 입력" then textWidth = 80 end
    end
    
    local targetX = targetBtn.Position.X.Offset + (targetBtn.Size.X.Offset - textWidth) / 2
    
    tabIndicator.BackgroundTransparency = 0.4
    
    local tweenInfo = TweenInfo.new(0.23, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local indicatorTween = TweenService:Create(tabIndicator, tweenInfo, {
        Size = UDim2.new(0, textWidth, 0, 3),
        Position = UDim2.new(0, targetX, 0, 26),
        BackgroundTransparency = 0 
    })
    indicatorTween:Play()
    
    if categoryName == "자동 입력" then
        scrolling.Visible = false
        botFrame.Visible = true
    else
        scrolling.Visible = true
        botFrame.Visible = false
        update()
    end
end

